# PPF Backend - Environment Variables Configuration
# Copy this file to .env and configure for your environment

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=4000
NODE_ENV=development

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=3307
DB_USER=ppf_user
DB_PASSWORD=ppf_password_secure_change_in_production
DB_NAME=ppf_db

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000
# For multiple origins: CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# =============================================================================
# RATE LIMITING
# =============================================================================
# Window in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window per IP
RATE_LIMIT_MAX=100

# =============================================================================
# API KEY AUTHENTICATION (RECOMMENDED FOR PRODUCTION)
# =============================================================================
# Generate secure random keys: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Multiple keys can be comma-separated
API_KEYS=your-super-secret-api-key-here-change-in-production

# Example: API_KEYS=key1_for_frontend,key2_for_mobile_app,key3_for_admin

# =============================================================================
# ADDITIONAL SECURITY SETTINGS (OPTIONAL)
# =============================================================================
# Enable/disable audit logging
AUDIT_LOG_ENABLED=true

# Log file path (relative to backend directory)
AUDIT_LOG_PATH=./logs/security-audit.log

# Maximum log file size in MB before rotation
AUDIT_LOG_MAX_SIZE=10

# Number of old log files to keep
AUDIT_LOG_MAX_FILES=5
