{
    "info": {
        "_postman_id": "ppf-vehicle-api-collection",
        "name": "PPF – Vehicle Management API",
        "description": "Full test suite for the PPF Vehicle Management API. Tests vehicles CRUD and entries CRUD with filters.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:4000",
            "type": "string"
        },
        {
            "key": "vehicleId",
            "value": "",
            "type": "string"
        },
        {
            "key": "entryId",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Health",
            "item": [
                {
                    "name": "GET /api/health",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "pm.test('Has status ok', () => {",
                                    "  const body = pm.response.json();",
                                    "  pm.expect(body.status).to.eql('ok');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/health",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "health"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Vehicles",
            "item": [
                {
                    "name": "POST /api/vehicles – create",
