                                    "pm.test('Status 201', () => pm.response.to.have.status(201));",
                                    "pm.test('Has data', () => {",
                                    "  const body = pm.response.json();",
                                    "  pm.expect(body.data).to.be.an('object');",
                                    "  pm.expect(body.data.placa).to.eql('PPF-001');",
                                    "  pm.collectionVariables.set('vehicleId', String(body.data.id));",
